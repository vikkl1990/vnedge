# VNEDGE configuration — copy to .env and edit. NEVER commit .env.
# All keys must be TRADE-ONLY: withdrawal permission disabled, IP whitelist on.

# --- Mode ------------------------------------------------------------------
# backtest | paper | shadow | live_small | live_full | emergency_reduce_only
VNEDGE_TRADING_MODE=backtest
# Live orders require THREE gates: a live_* mode, this flag, AND the exact
# confirmation phrase below. Any one missing -> no real orders, ever.
VNEDGE_LIVE_TRADING_ENABLED=false
VNEDGE_CONFIRM_LIVE_TRADING=
# To go live (after the pre-live checklist passes), set:
# VNEDGE_CONFIRM_LIVE_TRADING=I_UNDERSTAND_THIS_IS_HIGH_RISK
VNEDGE_LIVE_SMALL_CAPITAL_CAP_USD=100

# --- Risk (see src/vnedge/config/risk_config.py for meaning of each) -------
VNEDGE_RISK__MAX_DAILY_LOSS_USD=20
VNEDGE_RISK__RISK_PER_TRADE_PCT=1.0
VNEDGE_RISK__MAX_LEVERAGE_PER_POSITION=5
# Setting leverage above 10 also requires:
# VNEDGE_RISK__ACKNOWLEDGE_HIGH_LEVERAGE=true
VNEDGE_RISK__MAX_EFFECTIVE_ACCOUNT_LEVERAGE=2.0
VNEDGE_RISK__MAX_OPEN_POSITIONS=2
VNEDGE_RISK__MAX_DRAWDOWN_PCT=15
VNEDGE_RISK__MIN_ACCOUNT_EQUITY_USD=100

# --- Exchange keys (trade-only!) --------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

DELTA_API_KEY=
DELTA_API_SECRET=

# --- Alerts -----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
