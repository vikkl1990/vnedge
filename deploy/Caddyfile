# TLS front for the read-only dashboard. Self-signed ("internal") certs —
# the browser will warn once; the point is encrypting the token in transit.
# The dashboard itself remains token-gated and read-only.
{
	auto_https disable_redirects
}

https://:8765 {
	tls /certs/cert.pem /certs/key.pem
	reverse_proxy multi-lane-shadow:8080
}
